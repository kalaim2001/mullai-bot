@page "/"
@rendermode InteractiveServer
@using Mullai.Abstractions.Orchestration
@using Mullai.Abstractions.Messaging
@using Mullai.Agents
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text
@using Markdig
@inject IPlanner Planner
@inject IWorkflowEngine WorkflowEngine
@inject AgentFactory AgentFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Mullai Chat</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <h2>Mullai Assistant</h2>
        <div class="status-badge @(hubConnection?.State == HubConnectionState.Connected ? "online" : "offline")">
            @(hubConnection?.State == HubConnectionState.Connected ? "Connected" : "Reconnecting...")
        </div>
    </div>

    <div class="chat-history" @ref="chatHistoryRef">
        @foreach (var msg in messages)
        {
            <div class="message @(msg.IsUser ? "user-message" : "agent-message")">
                <div class="message-content">@((MarkupString)Markdig.Markdown.ToHtml(msg.Content, _pipeline))</div>
                @if (msg.TaskUpdates.Any())
                {
                    <div class="task-log">
                        @foreach (var update in msg.TaskUpdates)
                        {
                            <div class="task-step">@update</div>
                        }
                    </div>
                }
            </div>
        }
        @if (isThinking)
        {
            <div class="message agent-message thinking-message">
                <div class="message-content">Thinking...</div>
            </div>
        }
    </div>

    <div class="chat-input-area">
        <textarea @bind="currentInput" @bind:event="oninput" @onkeydown="HandleKeyDown" 
                  placeholder="Ask a question..." rows="1"></textarea>
        <button @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(currentInput) || isThinking)">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        </button>
    </div>
</div>

<style>
    :root {
        --primary: #6366f1;
        --bg-color: #0f172a;
        --surface: #1e293b;
        --text-primary: #f8fafc;
        --text-secondary: #94a3b8;
        --user-msg: #4f46e5;
        --agent-msg: #334155;
    }

    body {
        margin: 0;
        background-color: var(--bg-color);
        color: var(--text-primary);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }
    
    .chat-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
        box-sizing: border-box;
    }

    .chat-header {
        text-align: center;
        padding: 1rem 0;
        border-bottom: 1px solid var(--surface);
    }
    .chat-header h2 { margin: 0; font-weight: 600; color: var(--text-primary); }
    .status-badge { font-size: 0.7rem; padding: 2px 8px; border-radius: 10px; display: inline-block; margin-top: 4px; }
    .online { background: #10b981; color: white; }
    .offline { background: #ef4444; color: white; }

    .chat-history {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        scroll-behavior: smooth;
    }

    .message {
        max-width: 80%;
        display: flex;
        flex-direction: column;
    }

    .user-message {
        align-self: flex-end;
    }
    .user-message .message-content {
        background: var(--user-msg);
        border-radius: 1rem 1rem 0 1rem;
    }

    .agent-message {
        align-self: flex-start;
    }
    .agent-message .message-content {
        background: var(--agent-msg);
        border-radius: 1rem 1rem 1rem 0;
        border: 1px solid var(--surface);
    }
    
    .message-content {
        padding: 0.5rem 1rem;
        line-height: 1.5;
        word-wrap: break-word;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .task-log { font-size: 0.8rem; color: var(--text-secondary); margin-top: 8px; border-left: 2px solid var(--primary); padding-left: 8px; }
    .task-step { margin-bottom: 2px; }
    
    .thinking-message .message-content {
        animation: pulse 1.5s infinite;
        opacity: 0.7;
    }

    @@keyframes pulse {
        0% { opacity: 0.5; }
        50% { opacity: 1; }
        100% { opacity: 0.5; }
    }

    .chat-input-area {
        display: flex;
        gap: 0.5rem;
        align-items: flex-end;
        background: var(--surface);
        padding: 0.75rem;
        border-radius: 1rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        margin-bottom: 1rem;
    }

    textarea {
        flex: 1;
        background: transparent;
        border: none;
        color: var(--text-primary);
        resize: none;
        padding: 0.5rem;
        font-family: inherit;
        font-size: 1rem;
        line-height: 1.5;
        max-height: 150px;
    }
    textarea:focus { outline: none; }

    button {
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 50%;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
        flex-shrink: 0;
    }
</style>

@code {
    private string currentInput = "";
    private bool isThinking = false;
    private ElementReference chatHistoryRef;
    private HubConnection? hubConnection;
    private string sessionId = Guid.NewGuid().ToString();
    
    private List<ChatMessage> messages = new();
    private MarkdownPipeline _pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
    
    protected override async Task OnInitializedAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/fabric"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string, string, string?>("OnTaskUpdate", (nodeId, status, message) =>
        {
            var lastMsg = messages.LastOrDefault(m => !m.IsUser);
            if (lastMsg != null)
            {
                lastMsg.TaskUpdates.Add($"[{status}] {message ?? nodeId}");
                InvokeAsync(StateHasChanged);
            }
        });

        hubConnection.On<string, string>("OnAgentToken", (agentName, token) =>
        {
            var lastMsg = messages.LastOrDefault(m => !m.IsUser);
            if (lastMsg != null)
            {
                lastMsg.Content += token;
                isThinking = false;
                InvokeAsync(StateHasChanged);
            }
        });

        await hubConnection.StartAsync();
        await hubConnection.SendAsync("JoinSession", sessionId);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentInput) || isThinking)
            return;

        var userText = currentInput;
        currentInput = "";
        
        messages.Add(new ChatMessage { Content = userText, IsUser = true });
        isThinking = true;
        
        await ScrollToBottom();
        StateHasChanged();

        var agentMsg = new ChatMessage { Content = "", IsUser = false };
        messages.Add(agentMsg);

        try
        {
            var graph = await Planner.PlanAsync(userText, cancellationToken: default);
            foreach(var node in graph.Nodes) 
            {
                node.Metadata["SessionId"] = sessionId;
            }

            await WorkflowEngine.ExecuteAsync(graph);
        }
        catch (Exception ex)
        {
            agentMsg.Content = $"**Error:** {ex.Message}";
            isThinking = false;
            StateHasChanged();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("chat_scroll_bottom");
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private class ChatMessage
    {
        public string Content { get; set; } = "";
        public bool IsUser { get; set; }
        public List<string> TaskUpdates { get; set; } = new();
    }
}