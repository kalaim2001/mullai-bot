@page "/workflows/runs"
@rendermode InteractiveServer
@using Mullai.TaskRuntime.Abstractions
@using Mullai.TaskRuntime.Models
@using Mullai.Workflows.Abstractions
@implements IAsyncDisposable

@inject IMullaiTaskStatusStore StatusStore
@inject IWorkflowRegistry WorkflowRegistry

<PageTitle>Workflow Runs</PageTitle>

<div class="workflow-runs-page">
    <header class="workflow-runs-header">
        <div>
            <h1>Workflow Runs</h1>
            <p class="workflow-runs-subtitle">Monitor recent workflow executions.</p>
        </div>
    </header>

    <div class="workflow-runs-filters">
        <label>
            Workflow
            <select @bind="WorkflowFilter">
                <option value="">All</option>
                @foreach (var workflow in _workflowOptions)
                {
                    <option value="@workflow">@workflow</option>
                }
            </select>
        </label>
        <label>
            State
            <select @bind="StateFilter">
                <option value="">All</option>
                @foreach (var state in _stateOptions)
                {
                    <option value="@state">@state</option>
                }
            </select>
        </label>
    </div>

    <div class="workflow-runs-table">
        <div class="workflow-runs-row workflow-runs-header-row">
            <span>Workflow</span>
            <span>State</span>
            <span>Updated</span>
            <span>Summary</span>
        </div>
        @if (_filteredRuns.Count == 0)
        {
            <div class="workflow-runs-empty">No runs found.</div>
        }
        else
        {
            @foreach (var run in _filteredRuns)
            {
                <div class="workflow-runs-row">
                    <span class="workflow-runs-workflow">@run.WorkflowId</span>
                    <span class="workflow-runs-state">@run.State</span>
                    <span>@run.UpdatedAtUtc.ToLocalTime().ToString("g")</span>
                    <span class="workflow-runs-summary">@run.Summary</span>
                </div>
                @if (run.ShowDetails)
                {
                    <div class="workflow-runs-detail">
                        <pre>@run.FullText</pre>
                    </div>
                }
                <button class="workflow-runs-toggle" @onclick="() => ToggleDetails(run)">
                    @(run.ShowDetails ? "Hide Details" : "Show Details")
                </button>
            }
        }
    </div>
</div>

@code {
    private readonly List<WorkflowRunRow> _runs = [];
    private readonly List<string> _workflowOptions = [];
    private readonly List<string> _stateOptions = Enum.GetNames(typeof(MullaiTaskState)).ToList();
    private List<WorkflowRunRow> _filteredRuns = [];
    private readonly HashSet<string> _expandedTaskIds = new(StringComparer.OrdinalIgnoreCase);
    private string _workflowFilter = string.Empty;
    private string _stateFilter = string.Empty;
    private CancellationTokenSource? _pollingCts;
    private Task? _pollingTask;

    protected override void OnInitialized()
    {
        _workflowOptions.AddRange(WorkflowRegistry.GetAll().Select(w => w.Id));
        _pollingCts = new CancellationTokenSource();
        _pollingTask = PollAsync(_pollingCts.Token);
    }

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        var pollInterval = TimeSpan.FromMilliseconds(500);
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await RefreshRunsAsync(cancellationToken);
                    StateHasChanged();
                });
            }
            catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
            {
                break;
            }
            catch
            {
                // Keep UI responsive.
            }

            try
            {
                await Task.Delay(pollInterval, cancellationToken);
            }
            catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
            {
                break;
            }
        }
    }

    private async Task RefreshRunsAsync(CancellationToken cancellationToken)
    {
        var recent = await StatusStore.GetRecentAsync(200, cancellationToken);
        _runs.Clear();
        foreach (var snapshot in recent.Where(s => !string.IsNullOrWhiteSpace(s.WorkflowId)))
        {
            _runs.Add(new WorkflowRunRow
            {
                TaskId = snapshot.TaskId,
                WorkflowId = snapshot.WorkflowId!,
                State = snapshot.State.ToString(),
                UpdatedAtUtc = snapshot.UpdatedAtUtc,
                Summary = BuildRunSummary(snapshot),
                FullText = snapshot.Response ?? snapshot.Error ?? string.Empty,
                ShowDetails = _expandedTaskIds.Contains(snapshot.TaskId)
            });
        }

        ApplyFilters();
    }

    private string WorkflowFilter
    {
        get => _workflowFilter;
        set
        {
            if (_workflowFilter == value)
            {
                return;
            }

            _workflowFilter = value;
            ApplyFilters();
        }
    }

    private string StateFilter
    {
        get => _stateFilter;
        set
        {
            if (_stateFilter == value)
            {
                return;
            }

            _stateFilter = value;
            ApplyFilters();
        }
    }

    private void ApplyFilters()
    {
        _filteredRuns = _runs
            .Where(r => string.IsNullOrWhiteSpace(_workflowFilter) ||
                        string.Equals(r.WorkflowId, _workflowFilter, StringComparison.OrdinalIgnoreCase))
            .Where(r => string.IsNullOrWhiteSpace(_stateFilter) ||
                        string.Equals(r.State, _stateFilter, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(r => r.UpdatedAtUtc)
            .ToList();
    }

    private void ToggleDetails(WorkflowRunRow run)
    {
        run.ShowDetails = !run.ShowDetails;
        if (run.ShowDetails)
        {
            _expandedTaskIds.Add(run.TaskId);
        }
        else
        {
            _expandedTaskIds.Remove(run.TaskId);
        }
    }

    private static string BuildRunSummary(MullaiTaskStatusSnapshot snapshot)
    {
        if (!string.IsNullOrWhiteSpace(snapshot.Error))
        {
            return $"Error: {Truncate(snapshot.Error, 80)}";
        }

        if (!string.IsNullOrWhiteSpace(snapshot.Response))
        {
            return Truncate(snapshot.Response, 80);
        }

        return "No response yet.";
    }

    private static string Truncate(string text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        var oneLine = text.ReplaceLineEndings(" ");
        return oneLine.Length <= maxLength ? oneLine : $"{oneLine[..maxLength]}...";
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollingCts is null)
        {
            return;
        }

        _pollingCts.Cancel();
        if (_pollingTask is not null)
        {
            try
            {
                await _pollingTask;
            }
            catch (OperationCanceledException)
            {
                // Expected during shutdown.
            }
        }

        _pollingCts.Dispose();
    }

    private sealed class WorkflowRunRow
    {
        public string TaskId { get; init; } = string.Empty;
        public string WorkflowId { get; init; } = string.Empty;
        public string State { get; init; } = string.Empty;
        public DateTimeOffset UpdatedAtUtc { get; init; }
        public string Summary { get; init; } = string.Empty;
        public string FullText { get; init; } = string.Empty;
        public bool ShowDetails { get; set; }
    }
}
