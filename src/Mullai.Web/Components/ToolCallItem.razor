@using Mullai.TaskRuntime.Models

<div class="tool-item">
    <div class="tool-container">
        <div class="tool-badge" @onclick="ToggleExpand" title="Click to toggle details">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            <span class="tool-info">Tool: @FeedItem.Observation.ToolName <span class="tool-args">Arguments: @GetArgumentsString()</span></span>
            <svg class="expand-icon @(_isExpanded ? "expanded" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </div>
        
        @if (_isExpanded)
        {
            @if (!string.IsNullOrWhiteSpace(FeedItem.Observation.Result))
            {
                <div class="tool-result">
                    <code>@FeedItem.Observation.Result</code>
                </div>
            }
            
            @if (!string.IsNullOrWhiteSpace(FeedItem.Observation.Error))
            {
                <div class="tool-error">
                    <span>@FeedItem.Observation.Error</span>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public required ToolCallFeedItem FeedItem { get; set; }
    
    private bool _isExpanded;

    private void ToggleExpand() => _isExpanded = !_isExpanded;

    private string GetArgumentsString()
    {
        if (FeedItem.Observation.Arguments == null || FeedItem.Observation.Arguments.Count == 0)
            return "{}";
        
        try 
        {
            return System.Text.Json.JsonSerializer.Serialize(FeedItem.Observation.Arguments);
        }
        catch 
        {
            return "{...}";
        }
    }
}
