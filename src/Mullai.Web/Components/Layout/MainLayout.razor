@inherits LayoutComponentBase
@implements IDisposable

@inject NavigationManager NavigationManager

<div class="app-shell @(_sidebarOpen ? "sidebar-open" : string.Empty)">
    <aside class="app-sidebar" aria-label="Sidebar">
        <LeftNav OnNavigate="CloseSidebar" />
    </aside>

    <div class="app-overlay" @onclick="CloseSidebar" aria-hidden="true"></div>

    <main class="app-main">
        @if (!_isSettingsPage)
        {
            <TopNav Title="@_headerTitle"
                    Subtitle="@_headerSubtitle"
                    SessionId="@_sessionLabel"
                    Status="Active"
                    OnToggleSidebar="ToggleSidebar" />
        }
        <section class="app-content">
            <CascadingValue Value="this" IsFixed="true">
                @Body
            </CascadingValue>
        </section>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _sidebarOpen;
    private string _headerTitle = "Mullai";
    private string? _headerSubtitle;
    private string _sessionLabel = "Mullai Assistant";

    protected override void OnInitialized()
    {
        UpdateHeaderForLocation();
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateHeaderForLocation();
        _sidebarOpen = false;
        StateHasChanged();
    }

    private bool _isSettingsPage;
    
    private void UpdateHeaderForLocation()
    {
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        relative = relative.Split('?', '#')[0];

        _isSettingsPage = string.Equals(relative, "settings", StringComparison.OrdinalIgnoreCase);

        (_headerTitle, _headerSubtitle) = relative switch
        {
            "" => ("Chat", "Interactive runtime session"),
            "settings" => ("Settings", "Configure providers, models, and credentials"),
            "not-found" => ("Not Found", null),
            _ => ("Mullai", relative)
        };
    }

    public void ToggleSidebar()
        => _sidebarOpen = !_sidebarOpen;

    private void CloseSidebar()
        => _sidebarOpen = false;

    public void Dispose()
        => NavigationManager.LocationChanged -= HandleLocationChanged;
}
