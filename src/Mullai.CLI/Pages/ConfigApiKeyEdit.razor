@page "/config/apikeys/{ProviderName}"
@namespace Mullai.CLI.Pages

@using System
@using Microsoft.AspNetCore.Components
@using RazorConsole.Components
@using Spectre.Console
@using Mullai.CLI.Controllers

@inject ConfigController Config
@inject NavigationManager Nav

<Figlet Content="@ProviderName" Color="@Color.Blue" />

<Padder Padding="@(new Padding(1, 0, 0, 0))">
    <Rows>
        <Markup Content="Current API Key:" Foreground="@Color.White" Decoration="@Decoration.Bold" />
        @if (!string.IsNullOrEmpty(_maskedKey))
        {
            <Markup Content="@_maskedKey" Foreground="@Color.Blue" />
        }
        else
        {
            <Markup Content="Not Set" Foreground="@Color.Red" />
        }

        <Newline />
        <Markup Content="Enter new API key:" Foreground="@Color.White" />
        <TextInput @bind-Value="_newKey" Placeholder="Paste your API key..." OnSubmit="SaveKey" Expand="true" />

        <Newline />
        <Columns>
            <TextButton Content="  💾 Save Key  "
                        OnClick="SaveKey"
                        BackgroundColor="@Color.Grey15"
                        FocusedColor="@Color.Green" />
            <Markup Content="  " />
            <TextButton Content="  🗑 Delete Key  "
                        OnClick="ShowDeleteConfirm"
                        BackgroundColor="@Color.Grey15"
                        FocusedColor="@Color.Red" />
        </Columns>

        @if (_statusMessage != null)
        {
            <Newline />
            <Markup Content="@_statusMessage" Foreground="@_statusColor" />
        }
    </Rows>
</Padder>

<Newline />
<TextButton Content="  ← Back to API Keys  "
            OnClick="@(() => Nav.NavigateTo("/config/apikeys"))"
            BackgroundColor="@Color.Grey15"
            FocusedColor="@Color.Yellow" />

<ModalWindow IsOpened="_showDeleteConfirm">
    <Panel Border="BoxBorder.Double" BorderColor="@Color.Red" Title="Confirm Delete" TitleColor="@Color.Red">
        <Padder Padding="@(new Padding(2, 1, 2, 1))">
            <Rows>
                <Markup Content="@($"Delete API key for {ProviderName}?")" Foreground="@Color.White" />
                <Newline />
                <Columns>
                    <TextButton Content="   Yes   "
                                OnClick="DeleteKey"
                                BackgroundColor="@Color.Grey15"
                                FocusedColor="@Color.Green" />
                    <Markup Content="  " />
                    <TextButton Content="   No    "
                                OnClick="HideDeleteConfirm"
                                BackgroundColor="@Color.Grey15"
                                FocusedColor="@Color.Red" />
                </Columns>
            </Rows>
        </Padder>
    </Panel>
</ModalWindow>

<Newline />
<Align Horizontal="@HorizontalAlignment.Center">
    <Markup Content="Tab to navigate • Enter to submit" Foreground="@Color.Grey58" />
</Align>

@code {
    [Parameter]
    public string ProviderName { get; set; } = string.Empty;

    private string _newKey = string.Empty;
    private string? _maskedKey;
    private string? _statusMessage;
    private Color _statusColor = Color.Green;
    private bool _showDeleteConfirm;

    protected override void OnInitialized()
    {
        RefreshKeyDisplay();
    }

    private void RefreshKeyDisplay()
    {
        var currentKey = Config.GetApiKey(ProviderName);
        _maskedKey = !string.IsNullOrEmpty(currentKey)
            ? (currentKey.Length > 8 ? currentKey[..4] + "..." + currentKey[^4..] : "****")
            : null;
    }

    private Task SaveKey()
    {
        if (!string.IsNullOrWhiteSpace(_newKey))
        {
            Config.SaveApiKey(ProviderName, _newKey.Trim());
            _newKey = string.Empty;
            RefreshKeyDisplay();
            _statusMessage = "Key saved!";
            _statusColor = Color.Green;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private void ShowDeleteConfirm()
    {
        _showDeleteConfirm = true;
        StateHasChanged();
    }

    private void HideDeleteConfirm()
    {
        _showDeleteConfirm = false;
        StateHasChanged();
    }

    private void DeleteKey()
    {
        Config.DeleteApiKey(ProviderName);
        _showDeleteConfirm = false;
        RefreshKeyDisplay();
        _statusMessage = "Key deleted.";
        _statusColor = Color.Yellow;
        StateHasChanged();
    }
}
