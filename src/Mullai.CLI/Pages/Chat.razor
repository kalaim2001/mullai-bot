@page "/"
@namespace Mullai.CLI.Pages

@using System
@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console
@using Mullai.CLI.Controllers
@using Mullai.CLI.State
@using Mullai.Abstractions.Observability

@inject ChatOrchestrator Orchestrator
@inject ChatState State
@inject NavigationManager Nav
@inject IHostApplicationLifetime AppLifetime

@implements IDisposable

<Figlet Content="Mullai" Color="@Color.DeepPink3_1" />


<Padder Padding="@(new Padding(1, 0, 0, 0))">
    <Rows>
        @if (State.Messages.Count == 0 && !State.IsThinking)
        {
            <Markup Content="Welcome! Type a message below to start chatting." Foreground="@Color.Grey" />
            <Markup Content="Type /mode <chat|agent|team> to switch execution paths." Foreground="@Color.Grey58" />
            <Markup Content="Type /config to manage settings, /quit to exit." Foreground="@Color.Grey58" />
        }
        else
        {
            @foreach (var entry in GetVisibleEntries())
            {
                @if (entry is ChatMessage message)
                {
                    var sourceId = message.Metadata.GetValueOrDefault("SourceId")?.ToString() ?? "Mullai";
                    var isSubTask = sourceId.Contains("-sub") || sourceId.Length < 8; // Heuristic for sub-tasks or short IDs
                    
                    <Padder @key="GetKey(entry)" Padding="@(new Padding(isSubTask ? 2 : 0, 1, 0, 0))">
                        <Markup Content="@(message.IsUser ? "You" : sourceId)" 
                                Foreground="@(message.IsUser ? Color.Green : (isSubTask ? Color.Yellow : Color.Blue))" />
                        <Markup Content=" " />
                        @if (message.IsUser)
                        {
                            <Markup Content="@message.Content" />
                        }
                        else
                        {
                            <Markdown Content="@message.Content" />
                        }
                    </Padder>
                }
                else if (entry is ToolCallObservation toolCall)
                {
                    <Padder Padding="@(new Padding(0, 1, 0, 0))">
                        <Markup Content="@($"🔧 {toolCall.ToolName}")" Foreground="@Color.Cyan1" />
                        @if (!string.IsNullOrEmpty(toolCall.Result))
                        {
                            <Markup Content="@($"   ↳ {Truncate(toolCall.Result, 120)}")" Foreground="@Color.Grey" />
                        }
                        @if (!string.IsNullOrEmpty(toolCall.Error))
                        {
                            <Markup Content="@($"   ✗ {toolCall.Error}")" Foreground="@Color.Red" />
                        }
                    </Padder>
                }
            }
        }

        @if (State.CurrentGraph.Nodes.Count > 0)
        {
            <Padder Padding="@(new Padding(0, 1, 0, 0))">
                <Panel Title="@($"Execution Plan: {Orchestrator.CurrentMode}")" BorderColor="@Color.Grey37">
                    <Rows>
                        @foreach (var node in State.GetRootTasks())
                        {
                            @RenderTaskNode(node, 0)
                        }
                    </Rows>
                </Panel>
            </Padder>
        }

        @if (State.IsThinking)
        {
            <Padder Padding="@(new Padding(0, 1, 0, 1))">
                <Columns>
                    <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                    <Markup Content="Mullai is thinking..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
                </Columns>
            </Padder>
        }
    </Rows>
</Padder>

@if (State.Progress > 0 && State.Progress < 1)
{
    <Padder Padding="@(new Padding(0, 1, 0, 0))">
        <Markup Content="@GetProgressBarMarkup()" />
    </Padder>
}

<Padder Padding="@(new Padding(0, 1, 0, 0))">
    <Columns>
        <Markup Content="@($"Model: {Orchestrator.ModelName}")" Foreground="@Color.Cyan1" />
        <Markup Content="  " />
        <Markup Content="@($"Provider: {Orchestrator.ProviderName}")" Foreground="@Color.Cyan1" />
        <Markup Content="  " />
        <Markup Content="@($"Mode: {Orchestrator.CurrentMode}")" Foreground="@Color.Yellow" />
        <Markup Content="  " />
        @if (State.Progress > 0)
        {
            <Markup Content="@($"Progress: {(State.Progress * 100):0}%")" Foreground="@Color.Green" />
        }
    </Columns>
</Padder>

<TextInput @bind-Value="_currentInput" Placeholder="Type your message..." OnSubmit="HandleInput" Expand="true" />

<Align Horizontal="@HorizontalAlignment.Center">
    <Markup Content="Enter to send • /mode <name> • /config • /quit" Foreground="@Color.Grey58" />
</Align>

@code {
    private string _currentInput = string.Empty;
    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        State.StateChanged += OnStateChanged;

        if (!_initialized)
        {
            _initialized = true;
            await Orchestrator.InitialiseAsync();
        }
    }

    private RenderFragment RenderTaskNode(Mullai.Abstractions.Orchestration.TaskNode node, int depth) => __builder => {
        var statusColor = node.Status switch
        {
            Mullai.Abstractions.Orchestration.TaskStatus.Running => Color.Yellow,
            Mullai.Abstractions.Orchestration.TaskStatus.Completed => Color.Green,
            Mullai.Abstractions.Orchestration.TaskStatus.Failed => Color.Red,
            _ => Color.Grey
        };
        var icon = node.Status switch
        {
            Mullai.Abstractions.Orchestration.TaskStatus.Running => "⏳",
            Mullai.Abstractions.Orchestration.TaskStatus.Completed => "✅",
            Mullai.Abstractions.Orchestration.TaskStatus.Failed => "❌",
            _ => "○"
        };
        var indent = new string(' ', depth * 2);
        var connector = depth > 0 ? "┕ " : "";

        <Markup Content="@($"{indent}{connector}{icon} [{statusColor.ToMarkup()}]{node.AssignedAgent}:[/] {node.Description}")" />
        
        @foreach (var child in State.GetChildren(node.Id))
        {
            @RenderTaskNode(child, depth + 1)
        }
    };

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleInput()
    {
        if (string.IsNullOrWhiteSpace(_currentInput))
            return;

        var input = _currentInput.Trim();
        _currentInput = string.Empty;
        StateHasChanged();

        if (input.Equals("/quit", StringComparison.OrdinalIgnoreCase))
        {
            AppLifetime.StopApplication();
            return;
        }

        if (input.StartsWith("/mode", StringComparison.OrdinalIgnoreCase))
        {
            var modeStr = input.Length > 5 ? input[6..].Trim().ToLower() : string.Empty;
            if (string.IsNullOrEmpty(modeStr))
            {
                State.AddErrorMessage($"Current Mode: {Orchestrator.CurrentMode}. Available: chat, agent, team.");
            }
            else if (Enum.TryParse<Mullai.Abstractions.Orchestration.ExecutionMode>(modeStr, true, out var mode))
            {
                Orchestrator.CurrentMode = mode;
                State.AddErrorMessage($"Mode switched to: {mode} 🎭");
            }
            else
            {
                State.AddErrorMessage("Invalid mode. Use: /mode <chat|agent|team>");
            }
            return;
        }

        if (input.Equals("/config", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/config");
            return;
        }

        await Orchestrator.HandleMessageAsync(input);
    }

    private List<object> GetVisibleEntries()
    {
        return State.ChronologicalEntries.ToList();
    }

    private string GetProgressBarMarkup()
    {
        const int width = 30;
        var completed = (int)(State.Progress * width);
        var remaining = width - completed;
        var bar = new string('━', completed) + new string('─', remaining);
        return $"[deepskyblue1]{bar}[/] [green]{(State.Progress * 100):0}%[/] [grey]Working...[/]";
    }

    private static string Truncate(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return text;
        var singleLine = text.ReplaceLineEndings(" ");
        return singleLine.Length <= maxLength ? singleLine : singleLine[..maxLength] + "…";
    }
    
    private string GetKey(object entry)
    {
        return entry switch
        {
            ChatMessage m => $"{m.GetHashCode()}-{m.Content.Length}",
            ToolCallObservation t => t.GetHashCode().ToString(),
            _ => entry.GetHashCode().ToString()
        };
    }

    public void Dispose()
    {
        State.StateChanged -= OnStateChanged;
    }
}
